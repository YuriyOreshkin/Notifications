@model Notifications.WebUI.Models.AccountViewModel

@{
    ViewBag.Title = "Вход";
}

@using (Html.BeginForm("Login", "Account", new { @returnurl = Request.QueryString["returnurl"] }, FormMethod.Post, new { @class = "login-form-container form-horizontal", style = "height:auto;" }))
{
    <div style="width:400px;height:auto; left:50%;top:200px; margin-left:200px;">
        <h4 style="text-align:center;color:#6f7282;">Авторизация</h4>
        <br />
        @Html.ValidationSummary(false)
        <div class="control-group">
            <label class="control-label" for="inputEmail">Логин</label>
            <div class="controls">
                @Html.TextBoxFor(model => model.UserName, new { id = "inputEmail", placeholder = "Логин" })
            </div>
        </div>
        <div class="control-group">
            <label class="control-label" for="inputPassword">Пароль</label>
            <div class="controls">
                @Html.PasswordFor(model => model.Password, new { type = "password", id = "inputPassword", placeholder = "Пароль" })
            </div>
        </div>
        <div class="control-group">
            <div class="controls">
                <label class="checkbox">
                    @Html.EditorFor(model => model.RememberMe, new { type = "checkbox" }) Запомнить меня
                </label>
                <button type="submit" class="btn">Войти</button>
            </div>
        </div>
    </div>


}


